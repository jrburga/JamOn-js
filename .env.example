# ── Local development only ────────────────────────────────────────────────────
# Copy to client/.env.local and fill in values if you need to override defaults.
# In production (Railway) no env vars are required — the server auto-detects
# NODE_ENV=production and serves the built client from the same origin.

# Override the backend URL (client-side Vite variable).
# Leave unset in production; set to http://localhost:3001 for local dev.
VITE_SERVER_URL=http://localhost:3001

# Server port (Railway sets this automatically).
PORT=3001
